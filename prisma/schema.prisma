generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum StoreType {
  SHOPEE
  TIKTOK
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(USER)
  status        UserStatus     @default(ACTIVE)
  expiredAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  stores        Store[]

  @@map("users")
}

model Store {
  id                   String                @id @default(uuid())
  name                 String
  type                 StoreType
  description          String?
  link                 String?
  userId               String
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  products             Product[]
  skus                 Sku[]
  orders               Order[]
  financeTransactions  FinanceTransaction[]
  tikTokAds            TikTokAd[]
  shopeeAds            ShopeeAd[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@map("stores")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
}

enum CancelBy {
  SELLER
  USER
  SYSTEM
}

model Order {
  id            String         @id @default(uuid())
  orderNumber   String
  storeId       String
  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdDate   DateTime
  shippedDate   DateTime?
  deliveredDate DateTime?
  completedDate DateTime?
  status        OrderStatus    @default(PENDING)
  cancelBy      CancelBy?
  cancelReason  String?
  subtotal      Decimal        @db.Decimal(15, 2) @default(0)
  discount      Decimal        @db.Decimal(15, 2) @default(0)
  total         Decimal        @db.Decimal(15, 2) @default(0)
  shippingFee   Decimal        @db.Decimal(15, 2) @default(0)
  platformFee   Decimal        @db.Decimal(15, 2) @default(0)
  affiliateFee  Decimal        @db.Decimal(15, 2) @default(0)
  grandTotal    Decimal        @db.Decimal(15, 2) @default(0)
  totalHpp      Decimal        @db.Decimal(15, 2) @default(0)
  netTotal      Decimal        @db.Decimal(15, 2) @default(0)
  items         OrderItem[]
  customer      OrderCustomer?
  shipping      OrderShipping?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([orderNumber, storeId])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId           String?
  productId       String?
  sku             String   @default("")
  mpSkuId         String   @default("")
  productName     String
  productCategory String?
  qty             Int      @default(1)
  price           Decimal  @db.Decimal(15, 2) @default(0)
  discount        Decimal  @db.Decimal(15, 2) @default(0)
  total           Decimal  @db.Decimal(15, 2) @default(0)
  hpp             Decimal  @db.Decimal(15, 2) @default(0)
  hppTotal        Decimal  @db.Decimal(15, 2) @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("order_items")
}

model OrderCustomer {
  id         String  @id @default(uuid())
  orderId    String  @unique
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String?
  name       String
  phone      String?
  address    String?
  country    String?
  province   String?
  city       String?
  district   String?
  zipcode    String?

  @@map("order_customers")
}

model OrderShipping {
  id             String  @id @default(uuid())
  orderId        String  @unique
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name           String?
  serviceName    String?
  trackingNumber String?

  @@map("order_shippings")
}

model Product {
  id           String        @id @default(uuid())
  mpProductId  String
  name         String
  description  String?
  category     String?
  status       ProductStatus @default(ACTIVE)
  variantTypes String[]
  storeId      String
  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  skus         Sku[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([mpProductId, storeId])
  @@map("products")
}

model Sku {
  id        String   @id @default(uuid())
  mpSkuId   String
  sku       String
  price     Decimal  @db.Decimal(15, 2)
  hpp       Decimal  @db.Decimal(15, 2)
  variants  Json     @default("{}")
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mpSkuId, storeId])
  @@map("skus")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── Finance ──────────────────────────────────────────────────────────────────

enum TransactionType {
  ORDER
  ADS
  LOGISTIC
  WITHDRAW
}

enum CashFlow {
  IN
  OUT
}

model FinanceTransaction {
  id           String          @id @default(uuid())
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  date         DateTime
  type         TransactionType
  cashFlow     CashFlow
  source       String?
  referenceId  String?
  amount       Decimal         @db.Decimal(15, 2) @default(0)
  platformFee  Decimal         @db.Decimal(15, 2) @default(0)
  affiliateFee Decimal         @db.Decimal(15, 2) @default(0)
  shippingFee  Decimal         @db.Decimal(15, 2) @default(0)
  netAmount    Decimal         @db.Decimal(15, 2) @default(0)
  note         String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("finance_transactions")
}

// ─── TikTok Ads ───────────────────────────────────────────────────────────────

model TikTokAd {
  id           String   @id @default(uuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  accountId    String
  accountName  String
  campaignId   String
  campaignName String
  adGroupId    String
  adGroupName  String
  cost         Decimal  @db.Decimal(15, 2) @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  conversions  Int      @default(0)
  grossRevenue Decimal  @db.Decimal(15, 2) @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([storeId, date, adGroupId])
  @@map("tiktok_ads")
}

model ShopeeAd {
  id          String   @id @default(uuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  adName      String
  adType      String   @default("")
  productCode String   @default("")
  biddingMode String   @default("")
  adPlacement String   @default("")
  cost        Decimal  @db.Decimal(15, 2) @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  grossRevenue Decimal @db.Decimal(15, 2) @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, date, adName])
  @@map("shopee_ads")
}
