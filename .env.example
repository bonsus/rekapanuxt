# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/rekapnuxt"

# JWT Secrets — CHANGE these in production!
# Maps to nuxt.config runtimeConfig.jwtSecret
NUXT_JWT_SECRET="your-super-secret-jwt-key-min-32-chars-change-in-prod"
# Maps to nuxt.config runtimeConfig.jwtRefreshSecret
NUXT_JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars-change-in-prod"
